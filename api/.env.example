# Copy to api/.env and fill in. Loaded automatically by python-dotenv / Flask.

# --- Core ---
SECRET_KEY=change-me
OPENAI_API_KEY=

# --- TTS provider selection ---
# "elevenlabs" (default) or "sixtydb"
TTS_PROVIDER=elevenlabs

# --- ElevenLabs (used when TTS_PROVIDER=elevenlabs) ---
ELEVEN_KEY=

# --- 60db (used when TTS_PROVIDER=sixtydb) ---
SIXTYDB_API_KEY=
# Optional overrides:
# SIXTYDB_VOICE_ID=fbb75ed2-975a-40c7-9e06-38e30524a9a1
# SIXTYDB_OUTPUT_FORMAT=mp3   # mp3 | wav | ogg | flac
# SIXTYDB_BASE_URL=https://api.60db.ai
